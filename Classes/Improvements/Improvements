public class Improvements
{
    public string Name { get; set; }
    public List<Improvement> ImprovementList { get; set; } = new List<Improvement>();



    // Methods
    public void AddImprovement(Improvement i) => ImprovementList.Add(i);
    public void RemoveImprovement(Improvement i) => ImprovementList.Remove(i);
    public List<Improvement> GetImprovements() => ImprovementList;
}

public class Improvement { }  // Base 


public class InsulationRoof : Improvement
{
    public string Type { get; set; }
    public int Thickness { get; set; }
    public double RValue { get; set; }
}

public class InsulationWall : Improvement
{
    public string Type { get; set; }
    public int Thickness { get; set; }
    public double RValue { get; set; }
}

public class WindowSize : Improvement
{
    public double Area { get; set; }
}

public class WindowGlazing : Improvement
{
    public string Type { get; set; }
    public double RValue { get; set; }
    public double SHGC { get; set; }
}

public class Orientation : Improvement
{
    public string Direction { get; set; }
}

public class Occupancy : Improvement
{
    public int NumberOfPeople { get; set; }
}

public class WindowShading : Improvement
{
    public string Type { get; set; }
    public bool IsExternal { get; set; }
}
